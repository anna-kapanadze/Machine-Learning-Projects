        "train_end = int(len(all_participants) * 0.70)\n",
        "val_end = int(len(all_participants) * 0.90)\n",
        "\n",
        "train_participants = all_participants[:train_end]\n",
        "val_participants = all_participants[train_end:val_end]\n",
        "test_participants = all_participants[val_end:]\n",
        "\n",
        "print('Number of participants in training:', len(train_participants))\n",
        "print('Number of participants in validation:', len(val_participants))\n",
        "print('Number of participants in test:', len(test_participants))\n",
        "\n",
        "train_idx_C = MLENDHW_df[MLENDHW_df['participant'].isin(train_participants)].index\n",
