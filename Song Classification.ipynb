        "MLENDHW_table = []\n",
        "\n",
        "for file in files:\n",
        "    file_name = file.split('/')[-1]\n",
        "    participant_id = file.split('/')[-1].split('_')[0]\n",
        "    interpretation = file.split('/')[-1].split('_')[1]\n",
        "    attempt = file.split('/')[-1].split('_')[2]\n",
        "    song = file.split('/')[-1].split('_')[3].split('.')[0]\n",
        "    MLENDHW_table.append([file_name, participant_id, interpretation, attempt, song])\n",
        "\n",
        "MLENDHW_df = pd.DataFrame(MLENDHW_table, columns=['file_id', 'participant', 'interpretation', 'attempt', 'song']).set_index('file_id')\n",
        "print('Dataframe built:', MLENDHW_df.shape)"
