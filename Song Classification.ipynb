      "source": [
        "def getPitch(x, fs, winLen=0.03):\n",
        "    p = winLen * fs\n",
        "    frame_length = int(2 ** int(p - 1).bit_length()) + 256\n",
        "    hop_length = frame_length // 2\n",
        "    f0, voiced_flag, voiced_probs = librosa.pyin(y=x, fmin=80, fmax=450, sr=fs,\n",
        "                                                  frame_length=frame_length, hop_length=hop_length)\n",
        "    return f0, voiced_flag"
      ],
      "metadata": {
        "id": "yg92iSLfkdAS"
      },
      "execution_count": 255,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def getXy(files, labels_df, scale_audio=False):\n",
        "    X = []\n",
        "    y = []\n",
        "\n",
        "    for file in tqdm(files):\n",
        "\n",
        "        #getting song label from dataframe\n",
        "        file_id = file.split('/')[-1]\n",
        "        yi = labels_df.loc[file_id]['song']\n",
        "\n",
        "        #loading audio file & trimmed to 10 seconds\n",
        "        x, fs = librosa.load(file, sr=None, duration=10.0)\n",
        "\n",
        "        #scaling audio\n",
        "        if scale_audio:\n",
        "            x = x / np.max(np.abs(x))\n",
        "        f0, voiced_flag = getPitch(x, fs, winLen=0.02)\n",
        "\n",
        "\n",
        "        power = np.sum(x ** 2) / len(x)\n",
        "        pitch_mean = np.nanmean(f0) if np.mean(np.isnan(f0)) < 1 else 0\n",
        "        pitch_std = np.nanstd(f0) if np.mean(np.isnan(f0)) < 1 else 0\n",
        "        voiced_fr = np.mean(voiced_flag)\n",
        "\n",
        "        mfccs = librosa.feature.mfcc(y=x, sr=fs, n_mfcc=13)\n",
        "        mfccs_mean = np.mean(mfccs.T, axis=0)\n",
        "\n",
        "        chroma = librosa.feature.chroma_stft(y=x, sr=fs)\n",
        "        chroma_mean = np.mean(chroma.T, axis=0)\n",
        "\n",
        "        #all features into one vector\n",
        "        xi = [power, pitch_mean, pitch_std, voiced_fr]\n",
        "        xi = np.concatenate([xi, mfccs_mean, chroma_mean])\n",
        "\n",
        "        X.append(xi)\n",
        "        y.append(yi)\n",
        "\n",
        "    return np.array(X), np.array(y)"
      ],
      "metadata": {
        "id": "v_JZI7tdoqZX"
      },
      "execution_count": 256,
      "outputs": []
    },
